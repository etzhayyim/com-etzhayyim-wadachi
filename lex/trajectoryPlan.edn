{:lexicon 1
 :id "com.etzhayyim.wadachi.trajectoryPlan"
 :defs
 {:main
  {:type "record"
   :key "tid"
   :record
   {:type "object"
    :required ["tid" "deliveryRouteRef" "waypoints" "bufferZones" "speedProfile"]
    :properties {:tid {:type "string" :description "Transaction ID"}
                 :deliveryRouteRef {:type "string" :description "Reference to originating deliveryRoute"}
                 :waypoints {:type "string" :description "Sequence of (lat,lon,heading) waypoints"}
                 :bufferZones {:type "string" :description "Obstacle avoidance buffer zone coordinates"}
                 :speedProfile {:type "string" :description "Speed command profile (m/s over distance)"}
                 :determinismId {:type "string" :description "Commit hash for replay determinism (G6)"}}}}}}
