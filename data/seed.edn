;; wadachi 轍 — kotoba seed data (representative, R0)
;; ADR-2605242000  ·  :sourcing :representative (NOT authoritative)
;; A small worked example: a single delivery mission (intra-site, on-site factory material
;; delivery) flowing through route planning → trajectory → motion control → obstacle
;; avoidance → safety monitoring → telemetry log, with mission completion record,
;; energy reporting, and safety approval. Prices/metrics are R0 representative only.

[;; ════════════ Operator (SBT-gated eligibility, G10) ════════════
 {:sbt/operator-did "did:web:operator.example.etzhayyim.com"
  :sbt/active true
  :sbt/certification-level "R0"
  :sourcing :representative}

 ;; ════════════ Delivery Route (mission input) ════════════
 {:delivery-route/id "dr.demo.0001"
  :delivery-route/origin "35.6789,139.7006"
  :delivery-route/destination "35.6795,139.7015"
  :delivery-route/obstacles "static perimeter fence, 2m buffer"
  :delivery-route/payload-kg 45.0
  :delivery-route/site-map-ref "ipfs://QmSiteMap001"
  :sourcing :representative}

 ;; ════════════ Trajectory Plan (route planning output) ════════════
 {:trajectory-plan/id "tp.demo.0001"
  :trajectory-plan/route-ref "dr.demo.0001"
  :trajectory-plan/waypoints "35.6789,139.7006,0 35.6792,139.7010,45 35.6795,139.7015,90"
  :trajectory-plan/buffer-zones "perimeter +2m radius"
  :trajectory-plan/speed-profile "0.5 m/s constant"
  :trajectory-plan/determinism-id "abc123def456"
  :sourcing :representative}

 ;; ════════════ Steering Commands (motion control, 10 Hz sampled) ════════════
 {:steering-command/id "sc.demo.0001"
  :steering-command/wheel-angle 0.0
  :steering-command/throttle 0.3
  :steering-command/brake 0.0
  :steering-command/timestamp "2026-06-02T10:00:00Z"
  :sourcing :representative}
 {:steering-command/id "sc.demo.0002"
  :steering-command/wheel-angle 15.0
  :steering-command/throttle 0.3
  :steering-command/brake 0.0
  :steering-command/timestamp "2026-06-02T10:00:01Z"
  :sourcing :representative}

 ;; ════════════ Safety Status (monitoring output) ════════════
 {:safety-status/id "ss.demo.0001"
  :safety-status/pass true
  :safety-status/anomaly ""
  :safety-status/halt-required false
  :safety-status/reason "all thresholds nominal"
  :safety-status/timestamp "2026-06-02T10:02:30Z"
  :sourcing :representative}

 ;; ════════════ Energy Report (G12 tracking) ════════════
 {:energy-consumed-kwh 0.8
  :sourcing :representative}

 ;; ════════════ Mission Complete Record (telemetry log output) ════════════
 {:mission-complete-record/id "mcr.demo.0001"
  :mission-complete-record/route-ref "dr.demo.0001"
  :mission-complete-record/completion-timestamp "2026-06-02T10:02:30Z"
  :mission-complete-record/ipfs-cid "ipfs://QmTelemetry001"
  :mission-complete-record/gps-track "35.6789,139.7006 35.6792,139.7010 35.6795,139.7015"
  :mission-complete-record/energy-kwh 0.8
  :mission-complete-record/safety-summary "pass"
  :mission-complete-record/operator-did "did:web:operator.example.etzhayyim.com"
  :sourcing :representative}
 ]
