;; wadachi 轍 — obstacle_avoidance cell (langgraph, WASM runtime)
;; ADR-2605242000 · Phase 2 scaffold
{:cell/id "obstacle_avoidance"
 :cell/glyph "🛑"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/entry "src/wadachi/cells/obstacle_avoidance/state_machine.cljc"
 :cell/handler "handle_obstacle_avoidance"
 :cell/doc "steeringCommands + sensorFusion (LIDAR/camera/radar) → avoidanceAdjustments. Dynamically replan path if obstacle detected (G6 replay-able, G9 kotoba state)."
 :cell/state-graph
 {:nodes [:fuse-sensors :detect-obstacles :replan-avoidance]
  :entry :fuse-sensors
  :edges [[:fuse-sensors :detect-obstacles]
          [:detect-obstacles :replan-avoidance] [:replan-avoidance :end]]}
 :cell/llm
 {:provider :murakumo
  :endpoint "127.0.0.1:4000"
  :model "gemma3:4b"
  :charter-rider true}
 :cell/gates ["G6" "G8" "G9" "G11"]
 :cell/kotoba
 {:reads [:steering-command/id :steering-command/wheel-angle :sensor-fusion/lidar
          :sensor-fusion/camera :sensor-fusion/radar]
  :writes [:avoidance-adjustment/id :avoidance-adjustment/dynamic-heading
           :avoidance-adjustment/obstacle-detected :avoidance-adjustment/new-waypoint]}}
