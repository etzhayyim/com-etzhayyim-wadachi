;; wadachi 轍 — telemetry_log cell (langgraph, WASM runtime)
;; ADR-2605242000 · Phase 2 scaffold
{:cell/id "telemetry_log"
 :cell/glyph "📊"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/entry "py/agent.py"
 :cell/handler "handle_telemetry_log"
 :cell/doc "Full mission telemetry (GPS track, sensor streams, commands) → missionCompleteRecord (IPFS CID + MST record). IPFS-pinned for audit trail (G2)."
 :cell/state-graph
 {:nodes [:aggregate-mission-data :ipfs-pin-telemetry :create-mission-record]
  :entry :aggregate-mission-data
  :edges [[:aggregate-mission-data :ipfs-pin-telemetry]
          [:ipfs-pin-telemetry :create-mission-record] [:create-mission-record :end]]}
 :cell/llm
 {:provider :murakumo
  :endpoint "127.0.0.1:4000"
  :model "gemma3:4b"
  :charter-rider true}
 :cell/gates ["G2" "G8" "G9"]
 :cell/kotoba
 {:reads [:delivery-route/id :trajectory-plan/waypoints :steering-command/id
          :safety-status/id :energy-consumed-kwh]
  :writes [:mission-complete-record/id :mission-complete-record/ipfs-cid
           :mission-complete-record/gps-track :mission-complete-record/completion-timestamp
           :mission-complete-record/safety-summary]}}
