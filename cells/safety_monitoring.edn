;; wadachi 轍 — safety_monitoring cell (langgraph, WASM runtime)
;; ADR-2605242000 · Phase 2 scaffold
{:cell/id "safety_monitoring"
 :cell/glyph "⚠️"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/entry "py/agent.py"
 :cell/handler "handle_safety_monitoring"
 :cell/doc "motionTelemetry (speed, acceleration, tilt, wheel slip) → safetyStatus (pass | critical_anomaly | halt). Enforces KPI caps (G11) and energy budget (G12)."
 :cell/state-graph
 {:nodes [:ingest-telemetry :check-safety-thresholds :evaluate-halt-condition]
  :entry :ingest-telemetry
  :edges [[:ingest-telemetry :check-safety-thresholds]
          [:check-safety-thresholds :evaluate-halt-condition] [:evaluate-halt-condition :end]]}
 :cell/llm
 {:provider :murakumo
  :endpoint "127.0.0.1:4000"
  :model "gemma3:4b"
  :charter-rider true}
 :cell/gates ["G8" "G9" "G11" "G12"]
 :cell/kotoba
 {:reads [:motion-telemetry/speed-mps :motion-telemetry/acceleration-mps2
          :motion-telemetry/tilt-deg :motion-telemetry/wheel-slip :energy-consumed-kwh]
  :writes [:safety-status/id :safety-status/pass :safety-status/anomaly
           :safety-status/halt-required :safety-status/reason :safety-status/timestamp]}}
