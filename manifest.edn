 [{:gate/id "G1"  :gate/name "firmware-open-source"        :gate/rule "Vehicle control firmware open-source; no proprietary vehicle control logic"}
  {:gate/id "G2"  :gate/name "gps-logs-ipfs-pinned"        :gate/rule "GPS track + sensor logs IPFS-pinned (traceability, mission audit)"}
  {:gate/id "G3"  :gate/name "witness-signature"            :gate/rule "Witness signature ≥1 safety monitor + ≥1 route authority required for mission approval"}
  {:gate/id "G5"  :gate/name "charter-rider-compliance"    :gate/rule "Charter Rider §2(a-h) scanned; no armed vehicle, no weapons integration"}
  {:gate/id "G6"  :gate/name "trajectory-determinism"       :gate/rule "Trajectory is deterministic and replay-able @ 10 Hz; computational reproducibility required"}
  {:gate/id "G8"  :gate/name "murakumo-only-inference"      :gate/rule "Inference is Murakumo-only (KotobaLLM 127.0.0.1:4000); external LLM prohibited"}
  {:gate/id "G9"  :gate/name "kotoba-eavt-native"           :gate/rule "State is kotoba EAVT Datoms (mission/telemetry/trajectory); no SQL/RisingWave/Cypher"}
  {:gate/id "G10" :gate/name "personnel-vetting"            :gate/rule "All operator credentials SBT-gated (active Adherent SBT required for operation)"}
  {:gate/id "G11" :gate/name "kpi-caps"                     :gate/rule "KPI caps: R0 ≤1 m/s, payload ≤100 kg, LIDAR range ≥50m, mission duration ≤60 min"}
  {:gate/id "G12" :gate/name "energy-budget"                :gate/rule "Energy budget ≤5 kWh per mission; regenerative braking logged for transparency"}
  {:gate/id "G13" :gate/name "tithe-non-fiat"               :gate/rule "Payments are USDC Base L2 + ERC-4337 + TitheRouter 10% (no Stripe/fiat)"}
  {:gate/id "G14" :gate/name "no-server-key"                :gate/rule "Platform holds no key (member/operator signs commands + settlement)"}
  {:gate/id "G15" :gate/name "consent-bound"                :gate/rule "Real outward actions stay gated (compute-only R0; mission dispatch stops at 'intent')"}
  {:gate/id "G16" :gate/name "pii-encrypted"                :gate/rule "Operator/member PII encrypted via com.etzhayyim.encrypted.* (ADR-2605181100)"}
